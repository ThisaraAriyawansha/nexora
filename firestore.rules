rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Roles aren't set as auth custom claims, so the only way to gate by role
    // is to look up the caller's own profile document.
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdminOrAbove() {
      return isAuth() && myRole() in ['Super Admin', 'Admin'];
    }

    function isSuperAdmin() {
      return isAuth() && myRole() == 'Super Admin';
    }

    // Exactly the Admin tier (not Super Admin) — used only to carve Super
    // Admin docs out of what Admin can read, below.
    function isAdmin() {
      return isAuth() && myRole() == 'Admin';
    }

    // Granular per-action permissions for Admin/Manager/Cashier/Technician,
    // set via Settings > Team (see lib/permissions.ts, the JS mirror of these
    // defaults) — Admin manages Manager/Cashier/Technician, only Super Admin
    // manages Admin's own permissions (see the users/{userId} update rule
    // above for where that boundary is enforced on writes). Super Admin
    // always passes without ever consulting a permissions map — Super Admin
    // itself is never restricted.
    //
    // The `permissions` map is always written fully populated by the app
    // (createTeamUser/updateTeamUser/backfillUserPermissions in
    // lib/firestore.ts) once a Super Admin/Admin has touched that account, so
    // the fallback below only matters for accounts nobody has edited yet —
    // it's keyed off the caller's *role* so an Admin who's never had their
    // permissions map written still gets their historical full access
    // (myRole() == 'Admin' → true), while an un-backfilled Manager/Cashier/
    // Technician still gets the restrictive false default they always had.
    // `.data.get('permissions', {})` (not `.data.permissions`) on purpose —
    // accessing `.data.permissions` directly throws when the field is absent
    // entirely (any account nobody has ever saved via createTeamUser/
    // updateTeamUser/the backfill tool), which errors the whole rule out to
    // a deny instead of falling through to `key`'s default below. Routing
    // through `.get()` with an empty-map default means a fully-missing
    // `permissions` field behaves the same as an empty one.
    function hasPerm(key) {
      return isSuperAdmin() ||
        (isAuth() &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get(key, myRole() == 'Admin') == true);
    }

    // Same as hasPerm(), but falls back to true regardless of role. Used for
    // every key whose baseline in lib/permissions.ts's DEFAULT_TRUE_KEYS is
    // true for every role (products.edit, suppliers.editContact, and every
    // `.view` key) — hasPerm()'s fallback is `myRole() == 'Admin'`, which
    // would wrongly deny Manager/Cashier/Technician for a key their
    // `permissions` map doesn't have yet (e.g. any account saved before that
    // key existed), even though the client always assumes it defaults true
    // and renders/fetches accordingly. Getting this mismatched for a
    // rule-enforced key throws "Missing or insufficient permissions" the
    // moment that role's account hits a `.view`-gated read.
    function hasPermDefaultTrue(key) {
      return isSuperAdmin() ||
        (isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get(key, true) == true);
    }

    match /users/{userId} {
      // Job intake needs to list technicians to assign a job to, so any staff
      // member (not just Admin+) can read profiles with role == 'Technician' —
      // the rule only holds documents-that-are-technicians open, not the
      // full team roster.
      //
      // Admin can fetch any single profile by ID EXCEPT a Super Admin's —
      // Super Admin must be fully invisible to Admin, not just filtered out
      // client-side (the Settings > Team list already does that; this closes
      // the same gap at the data layer, e.g. against a direct devtools
      // getDoc()). Super Admin itself is unaffected, and a user can always
      // read their own doc.
      //
      // `get` (single-doc) and `list` (collection query) are split on
      // purpose: Firestore requires every document a `list` query could
      // possibly return to satisfy the rule, or it rejects the whole query —
      // so getTeamUsers()'s unfiltered `orderBy(createdAt)` query over the
      // whole collection would fail outright the moment any Super Admin
      // account exists, if list used this same role != 'Super Admin' check.
      // `list` therefore stays as permissive as the old combined rule was;
      // the Team page's client-side filter (isSuperAdmin || u.role !==
      // 'Super Admin') is what actually keeps Super Admin out of an Admin's
      // view of that query's results.
      allow get: if isAuth() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (isAdmin() && resource.data.role != 'Super Admin') ||
        resource.data.role == 'Technician'
      );
      allow list: if isAuth() && (isAdminOrAbove() || resource.data.role == 'Technician');

      // Team members are provisioned by Admin+ (see createTeamUser in lib/firestore.ts).
      // Admin can create Admin/Manager/Cashier accounts, but only a Super Admin
      // can create another Super Admin.
      allow create: if isAdminOrAbove() &&
        (request.resource.data.role != 'Super Admin' || isSuperAdmin());

      // A user may edit their own profile fields, but not their own role/status/
      // permissions — otherwise a Cashier could grant themselves Admin (or just
      // grant themselves every permission) by writing their own doc. Role/status/
      // permissions changes require Admin+, only a Super Admin can grant or
      // modify the Super Admin role itself, and only a Super Admin can change an
      // Admin's permissions (Admin manages Manager/Cashier/Technician, never a
      // peer Admin — matches the Settings > Team UI, which only ever shows the
      // permissions checklist for those combinations).
      // `.get('permissions', {})` rather than `.permissions` directly on both
      // sides — a doc predating this feature (never touched by
      // createTeamUser/updateTeamUser/the backfill tool) has no `permissions`
      // field at all, and accessing a fully-missing field throws instead of
      // yielding a comparable value, which would error this whole rule out to
      // a deny and block even a harmless self-service displayName edit.
      allow update: if isAuth() && (
        (request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.get('permissions', {}) == resource.data.get('permissions', {}))
        || (isAdminOrAbove()
            && (request.resource.data.role != 'Super Admin' || isSuperAdmin())
            && (resource.data.role != 'Super Admin' || isSuperAdmin())
            && (resource.data.role != 'Admin' || request.resource.data.get('permissions', {}) == resource.data.get('permissions', {}) || isSuperAdmin()))
      );

      allow delete: if isSuperAdmin();
    }

    match /brands/{id}          { allow read: if isAuth(); allow create, update: if isAuth(); allow delete: if hasPerm('brands.delete'); }
    match /main_categories/{id} { allow read: if isAuth(); allow create, update: if isAuth(); allow delete: if hasPerm('categories.delete'); }
    match /sub_categories/{id}  { allow read: if isAuth(); allow create, update: if isAuth(); allow delete: if hasPerm('categories.delete'); }
    match /suppliers/{id}       { allow read: if isAuth(); allow create: if isAuth(); allow update: if hasPermDefaultTrue('suppliers.editContact'); allow delete: if isAdminOrAbove(); }
    match /customers/{id}       { allow read: if isAuth(); allow create, update: if isAuth(); allow delete: if isAdminOrAbove(); }

    match /products/{productId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if hasPermDefaultTrue('products.edit');
      allow delete: if hasPerm('products.delete');

      match /batches/{batchId} {
        // Editing a batch's cost/price/qty is an Admin Edit action — tightened
        // from isAuth() so the Products-page "Edit Batch" quick-fix is no
        // longer usable by every logged-in staff member.
        allow read, create: if isAuth();
        allow update, delete: if hasPerm('products.batch.edit');
      }
      match /units/{unitId} {
        allow read, create, update: if isAuth();
        allow delete: if hasPerm('products.unit.delete');
      }
    }

    match /sales/{saleId} {
      allow read, create: if isAuth();
      // Cancelling a sale (status -> 'cancelled') reverses stock and loyalty
      // points, so it's restricted the same way the Bills page UI restricts
      // the cancel button: Admin or Super Admin. Other field updates stay open.
      allow update: if isAuth() &&
        (request.resource.data.status != 'cancelled' || hasPerm('bills.cancel'));
      allow delete: if isAdminOrAbove();

      match /saleItems/{itemId} {
        allow read, create: if isAuth();
        allow update, delete: if isAdminOrAbove();
      }
    }

    // Collection-group rule for saleItems — the Dashboard runs a
    // collectionGroup("saleItems") query across every sale's line items, and
    // Firestore only honors that against a rule declared with the {path=**}
    // wildcard; the nested match above alone does not cover it.
    match /{path=**}/saleItems/{itemId} {
      allow read: if isAuth();
    }

    // quotations is a single-owner collection (only the Quotations page reads
    // it), so unlike products/customers/suppliers/etc. its view permission is
    // safe to rule-enforce without breaking some other unrelated page.
    match /quotations/{id} { allow read: if hasPermDefaultTrue('quotations.view'); allow create, update: if isAuth(); allow delete: if hasPerm('quotations.delete'); }

    match /jobs/{id} {
      allow read, create, update: if isAuth();
      allow delete: if isAdminOrAbove();

      // Every job status change is logged here — an audit trail, so entries
      // are append-only for regular staff (no update/delete). Admin+ can
      // still delete them, same as saleItems, so the Settings "Clean
      // Collection" tool can purge a job's history along with the job itself.
      match /statusHistory/{entryId} {
        allow read, create: if isAuth();
        allow update, delete: if isAdminOrAbove();
      }
    }
    match /warranties/{id} { allow read, create, update: if isAuth(); allow delete: if isAdminOrAbove(); }

    // Single-owner collection (only the Stock Movements page reads it — it's
    // written to, not read, by sales/GRN/transfer/stock-out/batch-edit), so
    // its view permission is safe to rule-enforce.
    match /stock_movements/{id} {
      allow read: if hasPermDefaultTrue('stockMovements.view');
      allow create: if isAuth();
      allow update, delete: if isAdminOrAbove();
    }

    match /counters/{id} {
      allow read, create, update: if isAuth();
      allow delete: if isAdminOrAbove();
    }

    // grns/grnItems is single-owner (only the GRN page reads it — createGrn's
    // write transaction reads counters/suppliers, never grns itself), so its
    // view permission is safe to rule-enforce.
    match /grns/{id} {
      allow read: if hasPermDefaultTrue('grn.view');
      allow create: if hasPerm('grn.create');
      allow update: if hasPerm('grn.edit');
      allow delete: if isAdminOrAbove();

      match /grnItems/{itemId} {
        allow read: if hasPermDefaultTrue('grn.view');
        allow create: if hasPerm('grn.create');
        allow update: if hasPerm('grn.edit');
        allow delete: if isAdminOrAbove();
      }
    }

    match /stockTransfers/{id} {
      allow read: if hasPermDefaultTrue('stockTransfer.view');
      allow create: if hasPerm('stockTransfer.create');
      allow update: if hasPerm('stockTransfer.edit');
      allow delete: if isAdminOrAbove();

      match /transferItems/{itemId} {
        allow read: if hasPermDefaultTrue('stockTransfer.view');
        allow create: if hasPerm('stockTransfer.create');
        allow update: if hasPerm('stockTransfer.edit');
        allow delete: if isAdminOrAbove();
      }
    }

    // Note: stock-out's own creation flow reads /jobs for its job picker —
    // that stays isAuth() (jobs.view is UI-only, see PERMISSION_CATALOG),
    // so it's unaffected by stockOut.view.
    match /stockOuts/{id} {
      allow read: if hasPermDefaultTrue('stockOut.view');
      allow create: if hasPerm('stockOut.create');
      allow update: if hasPerm('stockOut.edit');
      allow delete: if isAdminOrAbove();

      match /stockOutItems/{itemId} {
        allow read: if hasPermDefaultTrue('stockOut.view');
        allow create: if hasPerm('stockOut.create');
        allow update: if hasPerm('stockOut.edit');
        allow delete: if isAdminOrAbove();
      }
    }

    // One-time migration guard docs (e.g. migrations/stockLocation) — only a
    // Super Admin can run/re-run a migration.
    match /migrations/{id} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // Recording a supplier payment adjusts a running balance, so — unlike
    // Manager-level GRN/Transfer/Stock-Out creation — this is Admin+ only,
    // the same tier as sale cancellation.
    match /supplierPayments/{id} {
      allow read: if isAuth();
      allow create: if hasPerm('suppliers.recordPayment');
      allow update: if hasPerm('suppliers.editPayment');
      allow delete: if isAdminOrAbove();
    }

    // Cash shift open/close/reconciliation. This is the first collection
    // where a non-Admin both creates AND later updates their own doc, so the
    // update rule field-pins financial values with
    // request.resource.data.X == resource.data.X the same way users/{userId}
    // (above) pins role/status to stop self-escalation — here it stops a
    // cashier from rewriting their own totals while closing out. No
    // writeAuditLog trail is written for shift actions: auditLog/{id} below
    // is create-gated to Admin+, so a Cashier-driven closeShift transaction
    // would fail outright trying to write there (every existing
    // writeAuditLog call site lives inside an Admin-gated adminUpdate*
    // function). jobs/{id}/statusHistory sets the precedent for routine
    // self-service staff actions instead using a plain isAuth() collection —
    // here that's just the shift doc's own timestamped fields.
    match /shifts/{id} {
      allow read: if isAuth();

      // Opening a shift: only for yourself, starting in the canonical
      // open/zeroed shape — cash/card/transfer totals can't be seeded as
      // anything but zero.
      allow create: if isAuth() &&
        request.resource.data.cashierId == request.auth.uid &&
        request.resource.data.status == 'open' &&
        request.resource.data.cashSalesTotal == 0 &&
        request.resource.data.cardSalesTotal == 0 &&
        request.resource.data.transferSalesTotal == 0 &&
        request.resource.data.openingFloat >= 0;

      // Three disjoint update paths:
      //  1) The owning cashier closes their own open shift — financial
      //     fields (float, running totals) must stay frozen; only status/
      //     closedAt/expectedCash/countedCash/variance/closeNote/reviewStatus
      //     may change.
      //  2) Manager+ reviews an already-closed shift — every financial field
      //     stays frozen, only the review fields move.
      //  3) createSale (lib/firestore.ts) bumping running totals on the
      //     caller's own still-open shift as each sale completes.
      allow update: if isAuth() && (
        (
          resource.data.cashierId == request.auth.uid &&
          resource.data.status == 'open' &&
          request.resource.data.status == 'closed' &&
          request.resource.data.cashierId == resource.data.cashierId &&
          request.resource.data.openingFloat == resource.data.openingFloat &&
          request.resource.data.cashSalesTotal == resource.data.cashSalesTotal &&
          request.resource.data.cardSalesTotal == resource.data.cardSalesTotal &&
          request.resource.data.transferSalesTotal == resource.data.transferSalesTotal
        )
        || (
          hasPerm('finance.reviewShift') &&
          resource.data.status == 'closed' &&
          request.resource.data.status == 'closed' &&
          request.resource.data.cashierId == resource.data.cashierId &&
          request.resource.data.openingFloat == resource.data.openingFloat &&
          request.resource.data.expectedCash == resource.data.expectedCash &&
          request.resource.data.countedCash == resource.data.countedCash &&
          request.resource.data.variance == resource.data.variance &&
          request.resource.data.cashSalesTotal == resource.data.cashSalesTotal &&
          request.resource.data.cardSalesTotal == resource.data.cardSalesTotal &&
          request.resource.data.transferSalesTotal == resource.data.transferSalesTotal
        )
        || (
          resource.data.cashierId == request.auth.uid &&
          resource.data.status == 'open' &&
          request.resource.data.status == 'open' &&
          request.resource.data.cashierId == resource.data.cashierId &&
          request.resource.data.openingFloat == resource.data.openingFloat
        )
      );

      allow delete: if isAdminOrAbove();
    }

    // General business expenses (rent, utilities, salaries, etc.) — distinct
    // from supplierPayments, which settle inventory purchases already priced
    // into each batch's costPrice. Manager+ can log one (same tier as GRN/
    // Transfer/Stock-Out creation); only Admin+ can delete, matching the
    // delete tier used everywhere else in this file.
    match /expenses/{id} {
      allow read: if isAuth();
      allow create: if hasPerm('finance.addExpense');
      allow update: if isAdminOrAbove();
      allow delete: if hasPerm('finance.deleteExpense');
    }

    // Generic Admin Edit audit trail — every writer of this collection is
    // itself an Admin-gated adminUpdate* function, so there's no reason to
    // leave the door open wider than that at the rules layer.
    match /auditLog/{id} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrAbove();
    }

    // Shop info shown on printed bills/quotations — readable by all staff,
    // editable by Admin+ only. (Previously had no rule at all, so every
    // read/write to this doc was silently denied by Firestore's default-deny.)
    match /shopSettings/{id} {
      allow read: if isAuth();
      allow write: if isAdminOrAbove();
    }
  }
}
